project_name       = "retailops"
environment        = "dev"
aws_region         = "eu-central-1"
owner              = "oskar"
cost_center        = "portfolio"
managed_by         = "terraform"
resource_lifecycle = "temporary"

additional_tags = {
  Workload = "platform-foundation"
  Sprint   = "sprint-10"
}

vpc_cidr_block = "10.20.0.0/16"

public_subnets = {
  a = {
    cidr_block        = "10.20.0.0/24"
    availability_zone = "eu-central-1a"
  }
  b = {
    cidr_block        = "10.20.1.0/24"
    availability_zone = "eu-central-1b"
  }
}

private_subnets = {
  a = {
    cidr_block        = "10.20.10.0/24"
    availability_zone = "eu-central-1a"
  }
  b = {
    cidr_block        = "10.20.11.0/24"
    availability_zone = "eu-central-1b"
  }
}


# IAM baseline
# The Terraform plan policy is created by default. Future CI/CD roles remain disabled
# until GitHub OIDC or Jenkins trusted AWS principals are intentionally configured.
enable_github_actions_plan_role = false
github_oidc_provider_arn        = null
github_repository               = null
github_branch                   = "main"

enable_jenkins_plan_role = false
jenkins_trusted_role_arns = []

# ECR baseline
# Repositories are intended for release and release-candidate images.
# Short-lived local and CI images can remain local until cloud publishing is enabled.
ecr_repositories = {
  api = {
    repository_suffix   = "api"
    image_tag_mutability = "IMMUTABLE"
    scan_on_push        = true
    max_image_count     = 20
  }
  frontend = {
    repository_suffix   = "frontend"
    image_tag_mutability = "IMMUTABLE"
    scan_on_push        = true
    max_image_count     = 20
  }
}
