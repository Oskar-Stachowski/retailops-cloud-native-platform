# RetailOps local Docker Compose example configuration.
#
# These values are intentionally simple LOCAL-ONLY defaults for development,
# portfolio demos, and CI smoke validation.
#
# Do not use these credentials for staging, production, cloud deployments,
# shared servers, or publicly exposed environments.
#
# For non-local environments:
# - set APP_ENV to the target environment, for example dev/staging/prod
# - override all default credentials
# - store secrets in AWS Secrets Manager, SSM Parameter Store, or protected CI/CD variables
# - do not expose database, broker, Prometheus, or Grafana ports publicly

APP_ENV=local

FRONTEND_PORT=3000
API_PORT=8000

# Local-only PostgreSQL defaults.
POSTGRES_DB=retailops
POSTGRES_USER=retailops
POSTGRES_PASSWORD=retailops
POSTGRES_PORT=5432

# Local-only observability/admin ports.
PROMETHEUS_PORT=9090
GRAFANA_PORT=3001
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=retailops

# Local-only Redpanda ports.
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=19644

# Frontend -> Backend API integration.
VITE_API_BASE_URL=http://localhost:8000
