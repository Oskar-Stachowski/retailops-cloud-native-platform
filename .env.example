# Local development only.
# Do not reuse these values for staging, production, or shared environments.

FRONTEND_PORT=3000
API_PORT=8000
POSTGRES_PORT=5432
REDPANDA_KAFKA_PORT=19092
REDPANDA_ADMIN_PORT=19644
PROMETHEUS_PORT=9090

APP_ENV=local

# Docker Compose uses the service name `db` for API-to-Postgres traffic:
# postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@db:5432/${POSTGRES_DB}
#
# For tools running directly on your host, use localhost and POSTGRES_PORT.
POSTGRES_DB=retailops
POSTGRES_USER=retailops_local
POSTGRES_PASSWORD=retailops_local_dev_password

# Host-side broker address for tools running outside Docker Compose.
# Compose services use redpanda:9092 internally.
RETAILOPS_BROKER_BOOTSTRAP_SERVERS=localhost:19092

# Browser-visible API URL. `/api` is proxied by Vite in local dev and by
# Nginx in the frontend container.
VITE_API_BASE_URL=/api
